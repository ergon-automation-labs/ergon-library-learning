#!/bin/bash
# Git pre-push hook for bot_army_learning
# Validates compilation and builds release before pushing to GitHub
# Tests run in Jenkins (not locally)

set -e


# Use absolute path to $MIX_BIN since git hooks have limited environment
MIX_BIN="/Users/abby/.local/share/mise/shims/mix"

REPO_ROOT="$(git rev-parse --show-toplevel)"
export HEX_HOME="$REPO_ROOT/.cache/hex"
export MIX_HOME="$REPO_ROOT/.cache/mix"
mkdir -p "$HEX_HOME" "$MIX_HOME"
echo "🔍 Running pre-push checks..."
echo ""

# Check if we're pushing to main
read local_ref local_oid remote_ref remote_oid
if [[ $remote_ref == "refs/heads/main" ]]; then
  echo "⚠️  Pushing to main branch - validating and building release..."
  echo ""

  # Ensure dependencies are up to date
  echo "📦 Installing dependencies..."
  $MIX_BIN deps.get || {
    echo "❌ Failed to install dependencies"
    exit 1
  }

  # Check for compilation issues (quick validation)
  echo ""
  echo "🔨 Compiling code..."
  $MIX_BIN compile --force || {
    echo "❌ Compilation failed - push aborted"
    exit 1
  }

  # Quick linting check (non-blocking)
  echo ""
  echo "📝 Running linter..."
  $MIX_BIN credo --strict || {
    echo "⚠️  Linting issues found (non-blocking, will fail in CI)"
  }

  # Run tests (required before release)
  echo ""
  echo "🧪 Running tests..."
  $MIX_BIN test || {
    echo "❌ Tests failed - push aborted"
    exit 1
  }

  # Build OTP release
  echo ""
  echo "📦 Building OTP release..."
  MIX_ENV=prod $MIX_BIN release --overwrite || {
    echo "❌ Release build failed - push aborted"
    exit 1
  }

  # Extract version and create GitHub release
  echo ""
  echo "🚀 Publishing release to GitHub..."
  VERSION=$(cat _build/prod/rel/learning_bot/releases/start_erl.data | awk '{print $2}')
  echo "Version: $VERSION"

  # Create tarball
  tar -czf learning_bot-$VERSION.tar.gz -C _build/prod/rel learning_bot/ || {
    echo "❌ Failed to create tarball"
    exit 1
  }
  echo "✓ Tarball created: learning_bot-$VERSION.tar.gz"

  if gh release view "v$VERSION" >/dev/null 2>&1; then
    echo "❌ GitHub release v$VERSION already exists."
    echo "   A prior run may have published the tarball while git push did not complete."
    echo "   Bump :version in mix.exs, commit, and push again (do not replace published assets)."
    exit 1
  fi

  # Create GitHub release
  gh release create v$VERSION learning_bot-$VERSION.tar.gz \
    --title "Release v$VERSION" \
    --notes "Learning Bot Elixir release v$VERSION. Automatically deployed by Jenkins." \
    --draft=false || {
    echo "❌ Failed to create GitHub release"
    exit 1
  }
  echo "✓ Release published to GitHub"

  # Cleanup build artifacts created by this hook
  echo ""
  echo "🧹 Cleaning up local release artifacts..."
  rm -f ./*.tar.gz
  rm -rf ./_build
  echo "✓ Cleanup complete"

  echo ""
  echo "✅ All checks passed, release built and published!"
  echo "📤 Proceeding with push..."
else
  echo "ℹ️  Pushing to feature branch - skipping validation"
fi

echo ""
exit 0
